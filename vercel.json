{
  "version": 2,
  "functions": {
    "api/*.cpp": {
      "runtime": "vercel-cpp@0.5.0"
    }
  },
  "routes": [
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/submit", "dest": "/api/main.cpp" },
    { "src": "/admin-panel", "dest": "/api/main.cpp" },
    { "src": "/options", "dest": "/public/options.html" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}